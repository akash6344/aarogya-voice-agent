# Voice agent only — models, database, and LiveKit worker credentials.
# Copy to .env and fill in values. Never commit .env.

# LiveKit worker (same project as web, used to register and join rooms)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# STT (user-selectable in web UI): deepgram | sarvam | elevenlabs
DEFAULT_STT_PROVIDER=deepgram
DEEPGRAM_API_KEY=
SARVAM_API_KEY=

# TTS — per language. ElevenLabs has NO real-time Telugu.
# English + Hindi -> ElevenLabs Flash v2.5; Telugu -> Sarvam Bulbul
ELEVEN_API_KEY=
# Free tier: use PREMADE voices only (e.g. Sarah=EXAVITQu4vr4xnSDxMaL)
ELEVEN_TTS_MODEL=eleven_flash_v2_5
ELEVEN_VOICE_ID=
ELEVEN_VOICE_ID_EN=
ELEVEN_VOICE_ID_HI=
SARVAM_TTS_MODEL=bulbul:v2
SARVAM_TTS_SPEAKER=anushka

# LLM — auto (recommended): Gemini for best quality, Ollama only when Gemini rate-limits.
# Other modes: gemini (cloud only) | ollama (local only)
LLM_PROVIDER=auto
OLLAMA_MODEL=llama3.1:latest
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_TIMEOUT=90
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-001

# Neon PostgreSQL
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
CLINIC_TIMEZONE=Asia/Kolkata
