# Web app only — token service + public endpoint protection.
# Copy to .env.local and fill in values. Never commit .env.local.
#
# LiveKit: use the SAME values as agent/.env (LIVEKIT_URL, API_KEY, API_SECRET).

# LiveKit (server-side; never prefix secrets with NEXT_PUBLIC_)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Optional public-endpoint protection
ALLOWED_ORIGINS=http://localhost:3000
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
MAX_CALLS_PER_IP_PER_HOUR=10
